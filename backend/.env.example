# Lokal utvikling - kopier til .env og fyll inn
PORT=3000

# Railway setter DATABASE_URL automatisk når du legger til Postgres-plugin
DATABASE_URL=postgresql://user:pass@localhost:5432/escapebox

# Kommaseparert liste av tillatte frontend-domener (eller * for alle under utvikling)
FRONTEND_URL=http://localhost:5173,https://din-app.netlify.app

# Bytt UT i produksjon - brukes til å signere JWT
JWT_SECRET=bytt-meg-til-noe-langt-og-tilfeldig

# Kun brukt ved første oppstart hvis admin-tabellen er tom
DEFAULT_ADMIN_PASSWORD=changeme123
